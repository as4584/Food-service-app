{
  "expo": {
    "name": "NJ Eats",
    "slug": "shore-eats",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "shoreeats",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shoreeats.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "NJ Eats uses your location to show nearby restaurants and estimate delivery distance and time.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F3EC"
      },
      "package": "com.shoreeats.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#F7F3EC"
        }
      ],
      "expo-font",
      "expo-audio",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "NJ Eats uses your location to show nearby restaurants and estimate delivery distance and time."
        }
      ]
    ],
    "extra": {
      "router": {}
    }
  }
}
