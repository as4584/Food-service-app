{
  "expo": {
    "name": "Shore Eats",
    "slug": "shore-eats",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "shoreeats",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shoreeats.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FDF6E9"
      },
      "package": "com.shoreeats.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FDF6E9"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {}
    }
  }
}
